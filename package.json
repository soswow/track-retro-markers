{
  "name": "track-retro-markers",
  "version": "1.0.0",
  "description": "Track retro-reflective markers in video footage and export marker positions plus rendered tracking videos.",
  "type": "module",
  "bin": {
    "track-retro-markers": "./src/cli.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "track": "tsx src/cli.ts",
    "server": "tsx src/server/index.ts",
    "web": "vite --host 127.0.0.1",
    "dev": "concurrently -k \"npm run server\" \"npm run web\"",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json && vite build",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fastify/static": "^8.1.0",
    "commander": "^14.0.3",
    "fastify": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.0.7"
  }
}
